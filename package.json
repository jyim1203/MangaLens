{
  "name": "manga-lens",
  "version": "0.1.0",
  "description": "Firefox extension that detects manga/comic images, translates the text via your own LLM API key, and overlays the translation in place.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run lint && npm run test",
    "lint:ext": "web-ext lint --source-dir dist",
    "start:firefox": "web-ext run --source-dir dist"
  },
  "dependencies": {
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@samrum/vite-plugin-web-extension": "^5.1.1",
    "@types/webextension-polyfill": "^0.12.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0",
    "web-ext": "^8.3.0"
  }
}
